# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Secret used to authenticate cron job requests
CRON_SECRET=your_cron_secret_here

# Supabase (from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site URL (http://localhost:3000 for dev, production URL for Vercel)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Microservice URLs (optional)
MICROSERVICE_JP_URL=https://doom-jp.vercel.app
MICROSERVICE_IN_URL=https://doom-in.vercel.app
MICROSERVICE_GT_URL=https://doom-gt.vercel.app
